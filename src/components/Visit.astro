---
import type { StudioInfo } from '../lib/sanity';

interface Props {
  info: StudioInfo;
}

const { info } = Astro.props;
---

<section class="visit" id="visit">
  <div class="container">
    <div class="visit__content animate-in">
      <h2 class="visit__title">Come Say Hi</h2>

      <div class="visit__details">
        <div class="visit__block">
          <h3 class="visit__label">Find Us</h3>
          <p class="visit__value">{info.address}</p>
        </div>

        {info.hours && info.hours.length > 0 && (
          <div class="visit__block">
            <h3 class="visit__label">Hours</h3>
            {info.hours.map((h) => (
              <p class="visit__value">
                <span class="visit__day">{h.day}</span>
                <span class="visit__hours">{h.hours}</span>
              </p>
            ))}
          </div>
        )}

        {info.email && (
          <div class="visit__block">
            <h3 class="visit__label">Get in Touch</h3>
            <p class="visit__value">
              <a href={`mailto:${info.email}`} class="link-underline">{info.email}</a>
            </p>
          </div>
        )}
      </div>
    </div>
  </div>
</section>

<style>
  .visit {
    position: relative;
    border-top: 1px solid rgba(26, 26, 26, 0.08);
  }

  .visit__title {
    font-size: var(--text-2xl);
    color: var(--color-ink);
    margin-bottom: var(--space-lg);
  }

  .visit__details {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .visit__block {
    padding-left: var(--space-sm);
    border-left: 2px solid var(--color-red);
  }

  .visit__label {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-light-gray);
    margin-bottom: 0.25rem;
    font-weight: 500;
  }

  .visit__value {
    color: var(--color-ink);
    font-size: var(--text-base);
    display: flex;
    gap: 0.75rem;
  }

  .visit__day {
    color: var(--color-warm-gray);
    min-width: 14ch;
  }

  .visit__hours {
    color: var(--color-ink);
  }
</style>
