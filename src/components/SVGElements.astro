  <line x1="23" y1="45" x2="23" y2="43" stroke="currentColor" stroke-width="0.75" opacity="0.5"/>
  <line x1="27" y1="55" x2="27" y2="53" stroke="currentColor" stroke-width="0.75" opacity="0.5"/>
  <line x1="20" y1="75" x2="30" y2="75" stroke="currentColor" stroke-width="1.5"/>
</svg>

<!-- Rose (simple line art) -->
<svg class="svg-rose" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 50 60" fill="none" aria-hidden="true">
  <path d="M25 60 L25 35" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
  <path d="M25 45 C20 42 14 44 12 48" stroke="currentColor" stroke-width="1" fill="none"/>
  <path d="M25 50 C30 47 36 49 38 53" stroke="currentColor" stroke-width="1" fill="none"/>
  <path d="M25 20 C25 20 15 18 13 25 C11 32 20 35 25 35 C30 35 39 32 37 25 C35 18 25 20 25 20Z"
    stroke="currentColor" stroke-width="1.5" fill="none"/>
  <path d="M20 24 C22 20 28 20 30 24" stroke="currentColor" stroke-width="1" fill="none"/>
  <path d="M18 28 C20 24 30 24 32 28" stroke="currentColor" stroke-width="1" fill="none"/>
  <path d="M22 16 C22 12 28 12 28 16" stroke="currentColor" stroke-width="1" fill="none"/>
</svg>

<!-- Arrow (pointing right, western style) -->
<svg class="svg-arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 80 20" fill="none" aria-hidden="true">
  <line x1="5" y1="10" x2="70" y2="10" stroke="currentColor" stroke-width="1.5"/>
  <path d="M65 4 L75 10 L65 16" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
  <line x1="15" y1="8" x2="15" y2="12" stroke="currentColor" stroke-width="1" opacity="0.5"/>
  <line x1="25" y1="8" x2="25" y2="12" stroke="currentColor" stroke-width="1" opacity="0.5"/>
</svg>

<!-- Snake (S-curve, classic tattoo) -->
<svg class="svg-snake" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 30 100" fill="none" aria-hidden="true">
  <path d="M15 5 C15 5 5 15 5 25 C5 35 25 40 25 50 C25 60 5 65 5 75 C5 85 15 95 15 95"
    stroke="currentColor" stroke-width="1.5" stroke-linecap="round" fill="none"/>
  <circle cx="13" cy="8" r="1" fill="currentColor"/>
  <circle cx="17" cy="8" r="1" fill="currentColor"/>
  <path d="M12 5 L15 2 L18 5" stroke="currentColor" stroke-width="1" fill="none"/>
</svg>

<style>
  svg {
    display: inline-block;
  }
  .svg-star { color: var(--color-red); }
  .svg-horseshoe,
  .svg-boot,
  .svg-cactus,
  .svg-rose,
  .svg-arrow,
  .svg-snake { color: var(--color-ink); }
  .svg-spur-star { color: var(--color-light-gray, #8A8580); }
</style>
