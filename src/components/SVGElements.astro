---
// Hand-drawn SVG decorative elements in fine-line western tattoo style
---

<!-- Red Star (from branding) -->
<svg class="svg-star" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 50 50" fill="none" aria-hidden="true">
  <path d="M25 3 L30 18 L46 20 L34 31 L37 47 L25 39 L13 47 L16 31 L4 20 L20 18 Z"
    stroke="currentColor" stroke-width="1.5" fill="currentColor"
    style="stroke-dasharray: 200; stroke-dashoffset: 200;">
  </path>
</svg>

<!-- Horseshoe -->
<svg class="svg-horseshoe" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 60 70" fill="none" aria-hidden="true">
  <path d="M12 65 L12 30 C12 14 22 5 30 5 C38 5 48 14 48 30 L48 65"
    stroke="currentColor" stroke-width="1.5" stroke-linecap="round" fill="none"/>
  <circle cx="12" cy="65" r="3" fill="currentColor"/>
  <circle cx="48" cy="65" r="3" fill="currentColor"/>
  <line x1="18" y1="22" x2="18" y2="28" stroke="currentColor" stroke-width="1"/>
  <line x1="24" y1="16" x2="24" y2="22" stroke="currentColor" stroke-width="1"/>
  <line x1="36" y1="16" x2="36" y2="22" stroke="currentColor" stroke-width="1"/>
  <line x1="42" y1="22" x2="42" y2="28" stroke="currentColor" stroke-width="1"/>
</svg>

<!-- Cowboy Boot -->
<svg class="svg-boot" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 60 80" fill="none" aria-hidden="true">
