---
import type { StudioInfo } from '../lib/sanity';

interface Props {
  info: StudioInfo;
}

const { info } = Astro.props;
---

<section class="about" id="about">
  <div class="container">
    <div class="about__content animate-in">
      <h2 class="about__heading">About the Shop</h2>

      <p class="about__text">{info.about}</p>

      <p class="about__badge">Female-Owned & Female-Operated</p>
    </div>
  </div>
</section>

<style>
  .about {
    position: relative;
  }

  .about__content {
    max-width: 650px;
  }

  .about__heading {
    font-size: var(--text-xl);
    margin-bottom: var(--space-md);
    color: var(--color-ink);
  }

  .about__text {
    font-size: var(--text-base);
    line-height: 1.8;
    color: var(--color-warm-gray);
    margin-bottom: var(--space-md);
  }

  .about__badge {
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-ink);
    border: 1px solid var(--color-ink);
    padding: 0.4rem 1rem;
    display: inline-block;
  }
</style>
