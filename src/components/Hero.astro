---
import type { StudioInfo } from '../lib/sanity';

interface Props {
  info: StudioInfo;
}

const { info } = Astro.props;
---

<section class="hero" id="top">
  <div class="hero__content">
    <p class="hero__location">Austin, TX</p>

    <h1 class="hero__title">
      <img src="/images/square-logo.png" alt="Too Bad Tattoo Studio" class="hero__logo" />
    </h1>

    <p class="hero__tagline">{info.tagline || 'Fine Line Tattoo'}</p>

    <a href="#artists" class="btn hero__cta">Meet Our Artists</a>
  </div>

  <!-- Scroll indicator -->
  <div class="hero__scroll" aria-hidden="true">
    <svg width="20" height="40" viewBox="0 0 20 40" fill="none">
      <path d="M10 5 L10 30 M5 25 L10 32 L15 25" stroke="var(--color-ink)" stroke-width="1" opacity="0.3" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </div>
</section>

<style>
  .hero {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    padding: var(--space-xl) 0 5rem;
  }

  .hero__content {
    text-align: center;
    position: relative;
    z-index: 2;
  }

  .hero__location {
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-warm-gray);
    margin-bottom: var(--space-sm);
  }

  .hero__title {
    margin-bottom: var(--space-sm);
  }

  .hero__logo {
    width: clamp(280px, 70vw, 550px);
    height: auto;
    margin: 0 auto;
  }

  .hero__tagline {
    font-size: var(--text-base);
    color: var(--color-light-gray);
    font-style: italic;
    margin: 0 auto var(--space-lg);
  }

  .hero__cta {
    border-color: var(--color-ink);
  }

  .hero__scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    animation: bobUpDown 2s ease-in-out infinite;
  }

  @keyframes bobUpDown {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(8px); }
  }
</style>
