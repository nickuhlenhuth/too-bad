---
import type { Artist } from '../lib/sanity';
import { urlFor } from '../lib/sanity';

interface Props {
  artist: Artist;
}

const { artist } = Astro.props;
const hasPortfolio = artist.portfolio && artist.portfolio.length > 0;
const hasPhoto = artist.photo;
---

<article class="artist-card">
  <div class="artist-card__header">
    <div class="artist-card__avatar">
      {hasPhoto ? (
        <img
          src={urlFor(artist.photo).width(400).height(400).format('webp').url()}
          alt={artist.name}
          width="400"
          height="400"
          loading="lazy"
        />
      ) : (
        <div class="artist-card__avatar-placeholder">
          <svg width="40" height="40" viewBox="0 0 50 50" fill="none" aria-hidden="true">
            <path d="M25 3 L30 18 L46 20 L34 31 L37 47 L25 39 L13 47 L16 31 L4 20 L20 18 Z"
              stroke="var(--color-cream-dark)" stroke-width="1.5" fill="none"/>
          </svg>
        </div>
      )}
    </div>

    <div class="artist-card__info">
      <h3 class="artist-card__name">
        {artist.name}
        {artist.isGuest && <span class="artist-card__guest-badge">Guest</span>}
      </h3>
      <p class="artist-card__bio">{artist.bio}</p>
    </div>
  </div>

  <!-- Portfolio Grid -->
  {hasPortfolio && (
    <div class="artist-card__portfolio">
      {artist.portfolio.slice(0, 6).map((img, i) => (
        <button
          class="artist-card__portfolio-item"
          data-lightbox
          data-src={urlFor(img).width(800).format('webp').url()}
          data-alt={`${artist.name} tattoo work ${i + 1}`}
          aria-label={`View ${artist.name}'s tattoo work ${i + 1}`}
        >
          <img
            src={urlFor(img).width(300).height(300).format('webp').url()}
            alt={`${artist.name} tattoo work ${i + 1}`}
            width="300"
            height="300"
            loading="lazy"
          />
        </button>
      ))}
    </div>
  )}

  <!-- Placeholder portfolio for dev -->
  {!hasPortfolio && (
    <div class="artist-card__portfolio">
      {[1,2,3,4,5,6].map((i) => (
        <div class="artist-card__portfolio-placeholder">
          <svg width="24" height="24" viewBox="0 0 50 50" fill="none" aria-hidden="true">
            <path d="M25 3 L30 18 L46 20 L34 31 L37 47 L25 39 L13 47 L16 31 L4 20 L20 18 Z"
              stroke="var(--color-cream-dark)" stroke-width="1" fill="none"/>
          </svg>
        </div>
      ))}
    </div>
  )}

  <!-- Action Links -->
  <div class="artist-card__actions">
    <a href={artist.bookingUrl} target="_blank" rel="noopener noreferrer" class="btn btn--red artist-card__book">
      Book with {artist.name}
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M7 17L17 7M17 7H7M17 7V17" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>

    <a href={artist.instagramUrl} target="_blank" rel="noopener noreferrer" class="artist-card__ig" aria-label={`${artist.name} on Instagram`}>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="2" y="2" width="20" height="20" rx="5"/>
        <circle cx="12" cy="12" r="5"/>
        <circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/>
      </svg>
    </a>
  </div>
</article>

<style>
  .artist-card {
    position: relative;
    padding: var(--space-md);
    border: 1px solid rgba(26, 26, 26, 0.1);
    background-color: rgba(250, 247, 243, 0.25);
  }

  /* Decorative corner ticks */
  .artist-card::before,
  .artist-card::after {
    content: '';
    position: absolute;
    width: 12px;
    height: 12px;
    border-color: var(--color-ink);
    border-style: solid;
    opacity: 0.2;
  }

  .artist-card::before {
    top: -1px;
    left: -1px;
    border-width: 1px 0 0 1px;
  }

  .artist-card::after {
    bottom: -1px;
    right: -1px;
    border-width: 0 1px 1px 0;
  }

  .artist-card__header {
    margin-bottom: var(--space-md);
  }

  .artist-card__avatar {
    width: 100%;
    aspect-ratio: 1;
    overflow: hidden;
    border: 1.5px solid rgba(26, 26, 26, 0.15);
    margin-bottom: var(--space-sm);
  }

  .artist-card__avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .artist-card__avatar-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-cream);
  }

  .artist-card__name {
    font-size: var(--text-xl);
    font-family: var(--font-display);
    margin-bottom: 0.25rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .artist-card__guest-badge {
    font-family: var(--font-body);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-warm-gray);
    border: 1px solid var(--color-cream-dark);
    padding: 0.15rem 0.5rem;
  }

  .artist-card__bio {
    font-size: var(--text-sm);
    color: var(--color-warm-gray);
    line-height: 1.5;
  }

  .artist-card__portfolio {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    margin-bottom: var(--space-md);
  }

  .artist-card__portfolio-item {
    aspect-ratio: 1;
    overflow: hidden;
    cursor: pointer;
    padding: 0;
    border: none;
    background: none;
  }

  .artist-card__portfolio-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .artist-card__portfolio-item:hover img {
    transform: scale(1.05);
  }

  .artist-card__portfolio-placeholder {
    aspect-ratio: 1;
    background-color: var(--color-cream);
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px dashed var(--color-cream-dark);
  }

  .artist-card__actions {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .artist-card__book {
    flex: 1;
    justify-content: center;
    font-size: 0.75rem;
    padding: 0.65rem 1rem;
  }

  .artist-card__ig {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border: 1.5px solid var(--color-ink);
    transition: border-color 0.2s ease;
    flex-shrink: 0;
  }

  .artist-card__ig:hover {
    background-color: var(--color-ink);
    color: var(--color-cream);
  }

</style>
